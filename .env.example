# Required: Anthropic API key for LLM chat functionality.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Finnhub API key for real-time WebSocket trades (preferred when set).
# Free tier covers all 50 sector tickers. Get one at https://finnhub.io/register.
FINNHUB_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data via REST polling.
# Used only when FINNHUB_API_KEY is unset.
MASSIVE_API_KEY=

# Provider precedence: FINNHUB_API_KEY > MASSIVE_API_KEY > built-in GBM simulator.
# If neither key is set, the simulator runs and no external services are called.

# Optional: Set to "true" to return deterministic mock LLM responses instead of
# calling Anthropic. Used by the E2E test suite and for offline development.
LLM_MOCK=false

# Required: Anthropic API key for LLM chat functionality.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# If not set or empty, the built-in market simulator is used (recommended for most users).
MASSIVE_API_KEY=

# Optional: Set to "true" to return deterministic mock LLM responses instead of
# calling Anthropic. Used by the E2E test suite and for offline development.
LLM_MOCK=false

{
  "name": "finally-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright E2E tests for FinAlly",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "report": "playwright show-report",
    "compose:up": "docker compose -f docker-compose.test.yml up -d --build",
    "compose:down": "docker compose -f docker-compose.test.yml down -v",
    "compose:logs": "docker compose -f docker-compose.test.yml logs -f app"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
